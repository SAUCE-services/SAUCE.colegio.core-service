stateDiagram-v2
    [*] --> Pendiente

    state Pendiente {
        [*] --> SinDeuda
        SinDeuda --> Facturado: Generar factura
        Facturado --> Pagado: Registrar pago
        Pagado --> Vencido: No pago en fecha
    }

    state Deuda {
        Pendiente --> Deuda: Saldo impago acumulado
        Deuda --> EnGestion: Inicio gestión de cobranza
        EnGestion --> Pagado: Pago recibido
        EnGestion --> Incobrable: Gestión fallida
    }

    state Pagado {
        Pendiente --> Pagado: Pago completo
        Facturado --> Pagado: Pago parcial/total
        Pagado --> [*]
    }

    state Incobrable {
        Incobrable --> [*]
    }

    note right of Pendiente
        Estados de Cuenta Corriente:
        Cada alumno tiene un ciclo
        de facturación mensual
    end note

    note right of Pagado
        Los pagos se registran con
        medio de pago, fecha y
        referencia a factura
    end note
